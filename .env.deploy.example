# ============================================================
# 部署配置（本机用，被 deploy-cn.sh 读取）
# 用法：cp .env.deploy.example .env.deploy && vim .env.deploy
#
# ⚠️  .env.deploy 已加入 .gitignore，不要提交！
# ============================================================

# ── 目标服务器 ─────────────────────────────────────────────
# SSH 用户（推荐建一个非 root 用户并加入 docker 组）
DEPLOY_USER=ubuntu

# 服务器 IP 或域名
DEPLOY_SERVER=YOUR_HOST

# SSH 端口（默认 22）
DEPLOY_PORT=22

# 远端部署目录（与 setup-server-cn.sh 一致）
DEPLOY_REMOTE_DIR=/opt/new-api

# ── 可选：构建参数 ─────────────────────────────────────────
# 镜像名称前缀（不需要改）
# IMAGE_PREFIX=xiang-api

# 构建平台（默认 linux/amd64）
# BUILD_PLATFORM=linux/amd64
