# ============================================================
# 生产环境变量配置
# 复制此文件为 .env.production 并修改所有 CHANGE_THIS_* 值
# ============================================================

# ── 数据库配置 ──────────────────────────────────────────────
# PostgreSQL 密码（必须修改！）
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# 数据库连接字符串
SQL_DSN=postgresql://root:CHANGE_THIS_TO_STRONG_PASSWORD@postgres:5432/new-api

# ── Redis 配置 ─────────────────────────────────────────────
# Redis 密码（必须修改！）
REDIS_PASSWORD=CHANGE_THIS_TO_REDIS_PASSWORD

# Redis 连接字符串
REDIS_CONN_STRING=redis://:CHANGE_THIS_TO_REDIS_PASSWORD@redis:6379

# ── 安全配置 ───────────────────────────────────────────────
# Session 密钥（必须修改！使用以下命令生成）
# openssl rand -base64 32
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_32_CHARS

# 加密密钥（用于加密上游 API Key，必须修改！）
# openssl rand -base64 32
ENCRYPT_KEY=CHANGE_THIS_TO_ENCRYPTION_KEY

# ── 应用配置 ───────────────────────────────────────────────
# 时区
TZ=Asia/Shanghai

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 批量更新
BATCH_UPDATE_ENABLED=true

# 服务器地址（用于生成回调 URL，修改为你的域名）
SERVER_ADDRESS=https://api.yourdomain.com

# ── 邮件配置（可选）────────────────────────────────────────
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=noreply@yourdomain.com
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=象汇 API <noreply@yourdomain.com>

# ── OAuth 配置（可选）──────────────────────────────────────
# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# 微信登录
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# ── 支付配置（可选，上线后配置）────────────────────────────
# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── 对象存储（可选）────────────────────────────────────────
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=

# ── 监控配置（可选）────────────────────────────────────────
# Sentry DSN
# SENTRY_DSN=

# Uptime Kuma
# UPTIME_KUMA_URL=
